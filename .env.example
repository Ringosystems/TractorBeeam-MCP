# TractorBeeam365 MCP — configuration. Copy to ".env" and fill in your values.
# An independent MCP for Veeam Backup for Microsoft 365 (VB365).
# Not affiliated with or endorsed by Veeam Software.

# =========================================================================
# VB365 connection (required — read-only review works with just these)
# =========================================================================
# IP or hostname of the "Veeam Backup Server" VM (the VB365 server).
VB365_HOST=192.168.1.XX
# VB365 RESTful API port (console default is 4443).
VB365_PORT=4443
# API version: v8 for VB365 v8.x, v7 for VB365 7.x.
VB365_API_VERSION=v8
# A VB365 account used to obtain an API token (DOMAIN\\user or .\\localuser or user@domain).
VB365_USERNAME=.\\svc-vb365-review
VB365_PASSWORD=changeme
# VB365 ships a self-signed cert by default. Leaving this false disables MITM
# protection on the link to VB365. Prefer pointing VB365_CA_BUNDLE at the server's
# certificate (verification ON against it), or set VB365_VERIFY_SSL=true with a
# trusted cert.
VB365_VERIFY_SSL=false
# Optional path to a CA bundle / the VB365 cert to trust (takes precedence; turns
# certificate verification ON against that file).
VB365_CA_BUNDLE=
# HTTP timeout (seconds) for config calls; restore data ops use VB365_RESTORE_TIMEOUT.
VB365_TIMEOUT=30
VB365_RESTORE_TIMEOUT=300

# =========================================================================
# MCP transport (stdio for local; streamable-http for the container)
# =========================================================================
MCP_TRANSPORT=stdio
# Defaults to loopback. Containers must set 0.0.0.0 to be reachable via the
# published port (Docker port-publishing is then the network boundary).
MCP_HOST=127.0.0.1
MCP_PORT=8000
# The HTTP transport has no per-caller identity, so it FAILS CLOSED. Set a long
# random secret here; clients then send "Authorization: Bearer <token>".
MCP_AUTH_TOKEN=
# Set true to serve HTTP with NO token (LAN-only / behind an auth reverse proxy).
MCP_ALLOW_UNAUTHENTICATED_HTTP=false
# Set true to also expose the write/restore tools over an HTTP transport (off by
# default; the operator tier is safest over stdio).
TB_ALLOW_WRITE_OVER_HTTP=false

# =========================================================================
# Microsoft Graph — OPTIONAL, enables gap-analysis (gap_* tools).
# Entra app with admin-consented READ scopes:
#   User.Read.All, Group.Read.All, Sites.Read.All, Directory.Read.All
# =========================================================================
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# =========================================================================
# Cloud object-lock cross-check — OPTIONAL, enables cloud_lock_audit.
# Backblaze B2 (S3-compatible):
B2_KEY_ID=
B2_APP_KEY=
B2_S3_ENDPOINT=                 # e.g. https://s3.us-west-004.backblazeb2.com
# AWS S3 / Glacier:
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# =========================================================================
# WRITE / RESTORE TIER — OPTIONAL, OFF BY DEFAULT.
# Leave these unset for a pure read-only reviewer (the safe default). Each flag
# registers a category of mutating tools; every such tool still requires a
# two-call confirm token and writes to the audit log.
# =========================================================================
TB_ENABLE_ACTIONS=false         # master switch — must be true for ANY write tool
TB_ALLOW_JOB_CONTROL=false      # action_job: start/stop/enable/disable a job
TB_ALLOW_REPORTS=false          # action_generate_report
TB_ALLOW_ORG_SYNC=false         # action_org_sync
TB_ALLOW_PROXY=false            # action_proxy: rescan / maintenance mode
TB_ALLOW_RESTORE=false          # restore_* : define + execute restores

# Confirm-token lifetime (seconds) and where the append-only audit log + any
# generated files (PST exports, reports) are written.
TB_CONFIRM_TTL_S=300
TB_AUDIT_LOG=audit/actions.jsonl
TB_DOWNLOAD_DIR=downloads

# M365 target credentials VB365 uses to WRITE during a restore-to-original or
# restore-to-different-location. NOT needed for read-only, job control, reports,
# or export-to-PST. Can also be supplied per-call in restore_define options.
VB365_RESTORE_USERNAME=
VB365_RESTORE_PASSWORD=
VB365_RESTORE_APP_ID=
